# ═══════════════════════════════════════════════════════
# Wynncraft Dashboard — 自定义入口
# 复制为 .env 后修改，所有改动重启后生效
# ═══════════════════════════════════════════════════════

# ── 玩家基础信息 ──────────────────────────────────────────
# 后端 API 查询用 ID（Wynncraft API URL 的一部分）
TARGET_PLAYER=Kasyu_pwq
# 前端/后端显示用的称呼（上线/下线/切服 消息中均使用此名称）
PLAYER_NAME=卡死鱼

# ── 运行时统计 ─────────────────────────────────────────────
# 前端"已监控"计时起始时间（ISO-8601 格式）
VITE_RUNTIME_START=2026-05-20T00:00:00

# ── 后端数据库 ─────────────────────────────────────────────
DATABASE_URL=sqlite:///backend/player_data.db
FETCH_INTERVAL_MINUTES=5

# ── Raid / 副本名称展示映射 ──────────────────────────────
# 复杂映射，改以下文件内的 RAID_NAME_MAP：
#   backend/app/constants.py
#   frontend/src/config/constants.js

# ── 排行榜 / 技能等级名称展示映射 ────────────────────────
# 复杂映射，改以下文件内的 RANKING_NAME_MAP：
#   frontend/src/config/constants.js
